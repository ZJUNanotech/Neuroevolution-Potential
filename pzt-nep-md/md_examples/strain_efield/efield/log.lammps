write_restart relax_init
System init for write_restart ...
undump 1
unfix 1
# ------------------------- LOOP FOR D33/D31 ----------------------------------------------
reset_timestep 0

# 应变参数,弛豫完之后再定义
variable lz0 equal lz
variable tmp_lz0 equal ${lz0} # 这一步将当前瞬间的值固化给 tmp_lz0
variable tmp_lz0 equal 81.3067453933656 
variable lx0 equal lx
variable tmp_lx0 equal ${lx0}
variable tmp_lx0 equal 81.2858215976409
variable ly0 equal ly
variable tmp_ly0 equal ${ly0}
variable tmp_ly0 equal 81.2692564481046
variable strain_33 equal (lz-v_tmp_lz0)/v_tmp_lz0
variable strain_31 equal (lx-v_tmp_lx0)/v_tmp_lx0
variable strain_32 equal (ly-v_tmp_ly0)/v_tmp_ly0
# The option defaults are mode = scalar, ave = one, start = 0, 有初始值的
fix strain_ave all ave/time 1000 10 20000 v_strain_33 v_strain_31 v_strain_32 start 0 file strain_ave.txt
fix strain all ave/time 20000 1 20000 v_strain_33 v_strain_31 v_strain_32 start 0 file strain.txt

dump 4 all custom ${d1} strain_efield.lammpstrj id type element xs ys zs
dump 4 all custom 1000 strain_efield.lammpstrj id type element xs ys zs
dump_modify 4 element Ti Zr Pb O # mass order
dump_modify 4 sort id

# case 1：0-500KV/cm,0.005V/埃,interval：50KV/cm-0.0005V/埃
variable a loop 10
label loop
variable amp equal v_a*0.0005
fix ELF all efield 0 0 v_amp
fix 4 all npt temp ${T2} ${T2} ${Tdamp} tri $p $p ${Pdamp}
fix 4 all npt temp 300 ${T2} ${Tdamp} tri $p $p ${Pdamp}
fix 4 all npt temp 300 300 ${Tdamp} tri $p $p ${Pdamp}
fix 4 all npt temp 300 300 0.1 tri $p $p ${Pdamp}
fix 4 all npt temp 300 300 0.1 tri 1 $p ${Pdamp}
fix 4 all npt temp 300 300 0.1 tri 1 1 ${Pdamp}
fix 4 all npt temp 300 300 0.1 tri 1 1 1
run 20000 # 应变浮动大，多弛豫一会儿
