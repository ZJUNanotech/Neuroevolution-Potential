LAMMPS (19 Nov 2024)
OMP_NUM_THREADS environment is not set. Defaulting to 1 thread. (../comm.cpp:99)
  using 1 OpenMP thread(s) per MPI task
variable project_name index PZT_0p50
variable T1 equal 200 # Kelvin
variable T2 equal 300 # Kelvin
variable T3 equal 400 # Kelvin
variable dt equal 0.001 # ps,1fs
variable p equal 1 # bar

variable d1 equal 1000 # thermo interval
variable d2 equal 10000 # dump interval
variable d3 equal 100000 # restart interval
variable Tdamp equal 100.0*${dt}
variable Tdamp equal 100.0*0.001
variable Pdamp equal 1000.0*${dt}
variable Pdamp equal 1000.0*0.001

# 电场参数
variable E_poling equal 0.005      # 500 KV/cm = 0.005 V/埃
variable E_step equal 0.0005       # 50 KV/cm/步,文献用的50KV/cm
variable E_max equal 0.005        # 500 KV/cm,不能大于极化电场
variable E_min equal -0.001	   # 100 KV/cm,不能大于矫顽电场，因为会退极化

# Input Script LAMMPS
# ------------------------ INITIALIZATION -----------------------------------------------
units metal
dimension 3
boundary p p p
atom_style atomic
# ------------------------ ATOMS DEFINITION -----------------------------------------------
fix charge all property/atom q ghost yes
read_data relax_300.lmp fix charge NULL charge
Reading data file ...
  triclinic box = (-0.32135348 -0.35421517 -0.32429781) to (80.921353 80.954215 80.924298) with tilt (-0.50689568 0.37902783 -0.44957773)
  4 by 4 by 4 MPI processor grid
  reading atoms ...
  40000 atoms
  reading velocities ...
  40000 velocities
  read_data CPU = 0.161 seconds
change_box all triclinic
Changing box ...
  triclinic box = (-0.32135348 -0.35421517 -0.32429781) to (80.921353 80.954215 80.924298) with tilt (-0.50689568 0.37902783 -0.44957773)
neighbor 2.0 bin
neigh_modify every 1 delay 0 check yes page 100000 one 2000 # default
comm_modify vel yes
# ------------------------ FORCE FIELD ---------------------------------------------
set type 1 charge 7.06		# Ti
Setting atom values ...
  4000 settings made for charge
set type 2 charge 5.85		# Zr
Setting atom values ...
  4000 settings made for charge
set type 3 charge 3.901  	# Pb
Setting atom values ...
  8000 settings made for charge
set type 4 charge -3.452 	# O
Setting atom values ...
  24000 settings made for charge

pair_style nep
pair_coeff * * ./nep.txt Ti Zr Pb O
#------------------------- INITIAL SETTING ------------------------------------------
timestep ${dt}
timestep 0.001
thermo ${d1}
thermo 1000
# ------------------------- THERMALIZATION ----------------------------------------------
dump 1 all custom ${d2} init.lammpstrj id type element xs ys zs # 500KV/cm下平衡
dump 1 all custom 10000 init.lammpstrj id type element xs ys zs 
dump_modify 1 element Ti Zr Pb O # mass order
dump_modify 1 sort id
# relax
fix ELF all efield 0 0 ${E_poling}
fix ELF all efield 0 0 0.005
fix 1 all npt temp ${T2} ${T2} ${Tdamp} tri $p $p ${Pdamp}
fix 1 all npt temp 300 ${T2} ${Tdamp} tri $p $p ${Pdamp}
fix 1 all npt temp 300 300 ${Tdamp} tri $p $p ${Pdamp}
fix 1 all npt temp 300 300 0.1 tri $p $p ${Pdamp}
fix 1 all npt temp 300 300 0.1 tri 1 $p ${Pdamp}
fix 1 all npt temp 300 300 0.1 tri 1 1 ${Pdamp}
fix 1 all npt temp 300 300 0.1 tri 1 1 1
run 50000 # 平衡50ps
