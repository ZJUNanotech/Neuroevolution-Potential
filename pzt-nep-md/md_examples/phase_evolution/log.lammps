variable project_name index PZT
variable T equal 800 # Kelvin
variable dt equal 0.0005 # ps
variable p equal 1 # bar

variable d1 equal 1000 # dump interval
variable d2 equal 10000 # thermo interval
variable d3 equal 100000 # restart interval
variable Tdamp equal 100.0*${dt}
variable Tdamp equal 100.0*0.0005
variable Pdamp equal 1000.0*${dt}
variable Pdamp equal 1000.0*0.0005
# Input Script LAMMPS
# ------------------------ INITIALIZATION -----------------------------------------------
units metal
dimension 3
boundary p p p
atom_style atomic
read_data Ti_0p50.lmp
