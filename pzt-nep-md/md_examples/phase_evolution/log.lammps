neigh_modify every 1 delay 0 check yes page 100000 one 2000 # default
comm_modify vel yes
# ------------------------ FORCE FIELD ---------------------------------------------
pair_style nep
pair_coeff * * ./nep.txt Ti Zr Pb O
#------------------------- INITIAL SETTING ------------------------------------------
timestep ${dt}
timestep 0.0005
thermo ${d2}
thermo 10000
thermo_style custom step temp etotal pe ke vol xlo xhi ylo yhi zlo zhi xy xz yz press pxx pyy pzz pyz pxz pxy

velocity all set 0 0 0
velocity all create 800 4928459 mom yes rot yes dist gaussian
run 0
